{
  "name": "better-seo-crawl",
  "version": "0.0.1",
  "description": "Crawl/index helpers aligned with @better-seo/core: robots.txt and sitemap XML builders (pure strings, no network). Optional syndication depth in later roadmap waves.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@better-seo/core": "0.0.1"
  },
  "scripts": {
    "build": "node ../../scripts/run-tsup.mjs",
    "test": "npm exec -- vitest run",
    "test:coverage": "npm exec -- vitest run --coverage",
    "lint": "npm exec -- eslint .",
    "typecheck": "npm exec -- tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.6",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
