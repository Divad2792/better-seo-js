{
  "name": "@better-seo/assets",
  "version": "0.0.1",
  "description": "Optional Node-side asset helpers for Better SEO: generate Open Graph PNGs (1200x630) from titles and themes with Satori and Resvg, embed logos, render light or dark card templates, and build favicon.ico plus PWA icon sizes and manifest data from a single source image using Sharp. Intended for build scripts, servers, and the @better-seo/cli—not for importing from Edge or lightweight client bundles.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "react": "^19.0.0",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5"
  },
  "scripts": {
    "build": "node ../../scripts/run-tsup.mjs",
    "test": "npm exec -- vitest run",
    "test:coverage": "npm exec -- vitest run --coverage",
    "lint": "npm exec -- eslint .",
    "typecheck": "npm exec -- tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.8",
    "@vitest/coverage-v8": "^3.0.6",
    "image-size": "^2.0.2",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
