{
  "name": "@better-seo/react",
  "version": "0.0.1",
  "description": "React SPA integration for @better-seo/core: map SEO documents to react-helmet-async (toHelmetProps, BetterSEOHelmet), request-scoped SEOProvider + useSEO, and register the 'react' adapter for seoForFramework. Peers: react, react-dom, react-helmet-async.",
  "license": "MIT",
  "type": "module",
  "sideEffects": true,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@better-seo/core": "0.0.1"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0",
    "react-helmet-async": ">=2.0.0"
  },
  "scripts": {
    "build": "node ../../scripts/run-tsup.mjs",
    "test": "npm exec -- vitest run",
    "test:coverage": "npm exec -- vitest run --coverage",
    "lint": "npm exec -- eslint .",
    "typecheck": "npm exec -- tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitest/coverage-v8": "^3.0.6",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
