{
  "name": "@better-seo/cli",
  "version": "0.0.1",
  "description": "Command-line interface for Better SEO workflows: create Open Graph PNGs with the og command and generate favicon plus PWA icon sets (and optional web app manifest) with the icons command, powered by @better-seo/assets. Exposes both better-seo and better-seo-cli binaries so you can run npx @better-seo/cli or wire stable script names in CI and local npm scripts.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "better-seo": "dist/cli.cjs",
    "better-seo-cli": "dist/cli.cjs"
  },
  "main": "./dist/run-cli.cjs",
  "types": "./dist/run-cli.d.ts",
  "exports": {
    ".": {
      "types": "./dist/run-cli.d.ts",
      "import": "./dist/run-cli.js",
      "require": "./dist/run-cli.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@better-seo/assets": "0.0.1",
    "@clack/prompts": "^1.2.0",
    "better-seo-crawl": "0.0.1"
  },
  "scripts": {
    "build": "node ../../scripts/run-tsup.mjs",
    "test": "npm exec -- vitest run",
    "test:coverage": "npm exec -- vitest run --coverage",
    "lint": "npm exec -- eslint .",
    "typecheck": "npm exec -- tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@vitest/coverage-v8": "^3.0.6",
    "image-size": "^2.0.2",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
