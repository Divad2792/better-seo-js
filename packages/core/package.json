{
  "name": "@better-seo/core",
  "version": "0.1.0",
  "description": "Framework-agnostic SEO core for JavaScript and TypeScript: build a canonical SEO document with createSEO and mergeSEO, emit HTML-safe JSON-LD via serializeJSONLD, validate in development, render plain meta tag descriptors, and plug in frameworks through a small adapter registry. Ships with zero runtime npm dependencies so Node, Edge, and browser bundles avoid heavy transitive deps. Use with @better-seo/next or your own adapter; optional OG and icons stay in @better-seo/assets.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {},
  "scripts": {
    "build": "node ../../scripts/run-tsup.mjs",
    "test": "npm exec -- vitest run",
    "test:coverage": "npm exec -- vitest run --coverage",
    "lint": "npm exec -- eslint .",
    "typecheck": "npm exec -- tsc -p tsconfig.json --noEmit",
    "size": "node ../../scripts/run-size-limit.mjs",
    "audit": "npm audit --audit-level=high"
  },
  "publishConfig": {
    "access": "public"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "18 KB"
    }
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@vitest/coverage-v8": "4.1.2",
    "tsup": "8.5.1",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  }
}
